# Backend server port
PORT=5000

# Gmail SMTP credentials (use your Gmail and an App Password)
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-gmail-app-password

# Receiver email for contact form submissions
CONTACT_RECEIVER=your-email@example.com

# Optional: frontend API base URL for deployed UI (leave empty in local dev with Vite proxy)
# Example: VITE_API_BASE_URL=https://your-backend-domain.com
VITE_API_BASE_URL=

# Web3Forms access key for contact form (frontend-only setup)
# Get one from https://web3forms.com
VITE_WEB3FORMS_ACCESS_KEY=REVOKED_WEB3FORMS_KEY
